@component('components/layout/admin', { title })

@slot('main')
  {{-- Stats Grid --}}
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <div class="bg-[#161b22] border border-gray-700 rounded-xl p-4">

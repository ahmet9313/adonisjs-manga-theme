<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title || 'Admin' }} - MangaHub</title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
</head>
<body class="bg-[#0d1117] min-h-screen text-gray-200" x-data="{ sidebarOpen: false }">

  {{-- Mobile overlay --}}
  <div x-show="sidebarOpen" @click="sidebarOpen = false"
       class="fixed inset-0 bg-black/50 z-40 lg:hidden" x-transition.opacity></div>

  {{-- Sidebar --}}
  <aside class="fixed top-0 left-0 z-50 h-full w-64 bg-[#161b22] border-r border-gray-700 flex flex-col transition-transform duration-200"
         :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'">
    {{-- Logo --}}
    <div class="p-5 border-b border-gray-700">
      <a href="/admin" class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">
        MangaHub Admin
      </a>
    </div>

    {{-- Navigation --}}
    <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
      <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium {{ request.url() === '/admin' ? 'bg-cyan-500/10 text-cyan-400' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }} transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
        Panel
      </a>
      <a href="/admin/seriler" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium {{ request.url().startsWith('/admin/seriler') ? 'bg-cyan-500/10 text-cyan-400' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }} transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        Seriler
      </a>
      <a href="/admin/bolumler" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium {{ request.url().startsWith('/admin/bolumler') ? 'bg-cyan-500/10 text-cyan-400' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }} transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Bölümler
      </a>
      <a href="/admin/turler" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium {{ request.url().startsWith('/admin/turler') ? 'bg-cyan-500/10 text-cyan-400' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }} transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
        Türler
      </a>
      <a href="/admin/yazarlar" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium {{ request.url().startsWith('/admin/yazarlar') ? 'bg-cyan-500/10 text-cyan-400' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }} transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
        Yazarlar
      </a>
      <a href="/admin/cizerler" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium {{ request.url().startsWith('/admin/cizerler') ? 'bg-cyan-500/10 text-cyan-400' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }} transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Çizerler
      </a>
      <a href="/admin/icerik-turleri" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium {{ request.url().startsWith('/admin/icerik-turleri') ? 'bg-cyan-500/10 text-cyan-400' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }} transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        İçerik Türleri
      </a>

      <div class="border-t border-gray-700 my-3"></div>

      <a href="/admin/profil" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium {{ request.url().startsWith('/admin/profil') ? 'bg-cyan-500/10 text-cyan-400' : 'text-gray-400 hover:bg-gray-800 hover:text-gray-200' }} transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Profil
      </a>
    </nav>

    {{-- Footer --}}
    <div class="p-4 border-t border-gray-700">
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-400 hover:bg-gray-800 hover:text-gray-200 transition mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        Siteye Dön
      </a>
      <form action="/admin/cikis" method="POST">
        {{ csrfField() }}
        <button type="submit" class="flex items-center gap-2 w-full px-3 py-2 rounded-lg text-sm text-red-400 hover:bg-red-900/20 hover:text-red-300 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Çıkış Yap
        </button>
      </form>
    </div>
  </aside>

  {{-- Main content --}}
  <div class="lg:ml-64 min-h-screen">
    {{-- Top bar --}}
    <header class="sticky top-0 z-30 bg-[#161b22]/80 backdrop-blur border-b border-gray-700">
      <div class="flex items-center justify-between px-4 lg:px-6 h-14">
        <div class="flex items-center gap-3">
          <button @click="sidebarOpen = !sidebarOpen" class="lg:hidden text-gray-400 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h2 class="text-lg font-semibold text-gray-200">{{ title || 'Panel' }}</h2>
        </div>
        <div class="text-sm text-gray-400">
          {{ auth.user.email }}
        </div>
      </div>
    </header>

    {{-- Page content --}}
    <main class="p-4 lg:p-6">
      @include('partials/admin/flash_messages')
      {{{ await $slots.main() }}}
    </main>
  </div>
</body>
</html>
